prefix=/usr/local/mxe/usr/x86_64-w64-mingw32.static
includedir=${prefix}/include
libdir=${prefix}/lib

Name: Pango FT2 and Pango Fc
Description: FreeType 2.0 and fontconfig font support for Pango
Version: 1.57.1
Requires: pango, glib-2.0 >=  2.82, gobject-2.0 >=  2.82, gio-2.0 >=  2.82, fribidi >=  1.0.6, harfbuzz >=  8.4.0, fontconfig >=  2.17.0, freetype2, cairo >=  1.18.0
Libs: -L${libdir} -lpangoft2-1.0 -lm
Cflags: -I${includedir}/pango-1.0
