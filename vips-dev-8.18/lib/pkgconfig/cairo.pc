prefix=/usr/local/mxe/usr/x86_64-w64-mingw32.static
includedir=${prefix}/include
libdir=${prefix}/lib

Name: cairo
Description: Multi-platform 2D graphics library
Version: 1.18.4
Requires: libpng >=  1.4.0, fontconfig >=  2.13.0, freetype2 >=  23.0.17, pixman-1 >=  0.40.0
Libs: -L${libdir} -lcairo -lm
Cflags: -I${includedir}/cairo -DCAIRO_WIN32_STATIC_BUILD
