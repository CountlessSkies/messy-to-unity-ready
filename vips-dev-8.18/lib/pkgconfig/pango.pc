prefix=/usr/local/mxe/usr/x86_64-w64-mingw32.static
includedir=${prefix}/include
libdir=${prefix}/lib

Name: Pango
Description: Internationalized text handling
Version: 1.57.1
Requires: glib-2.0 >=  2.82, gobject-2.0 >=  2.82, gio-2.0 >=  2.82, fribidi >=  1.0.6, harfbuzz >=  8.4.0, fontconfig >=  2.17.0, freetype2, cairo >=  1.18.0
Libs: -L${libdir} -lpango-1.0 -lm
Cflags: -I${includedir}/pango-1.0
