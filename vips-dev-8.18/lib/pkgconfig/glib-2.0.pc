prefix=/usr/local/mxe/usr/x86_64-w64-mingw32.static
bindir=${prefix}/bin
datadir=${prefix}/share
includedir=${prefix}/include
libdir=${prefix}/lib

glib_genmarshal=${bindir}/glib-genmarshal
gobject_query=${bindir}/gobject-query
glib_mkenums=${bindir}/glib-mkenums
glib_valgrind_suppressions=${datadir}/glib-2.0/valgrind/glib.supp

Name: GLib
Description: C Utility Library
Version: 2.89.0
Libs: -L${libdir} -lglib-2.0 -lintl -lm -lws2_32 -lwinmm
Libs.private: -lole32 -lshlwapi -luuid
Cflags: -I${includedir}/glib-2.0 -I${libdir}/glib-2.0/include -mms-bitfields
